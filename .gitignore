# ═══════════════════════════════════════════════════════════════
# ORION — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
ENV/

# ── Tool caches ──────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ── Secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── ORION-specific ───────────────────────────────────────────
checkpoints/
*.checkpoint

# ── Generated/Ephemeral Files ─────────────────────────────
eval_report_*.json
server.log
server_err.log
skills-lock.json
tree.txt
*.bat
