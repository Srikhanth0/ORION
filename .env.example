# ═══════════════════════════════════════════════════════════════
# ORION — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ─── LLM Providers ────────────────────────────────────────────

# vLLM (local, priority 1 — zero-cost inference)
VLLM_BASE_URL=http://localhost:8000/v1          # str: vLLM OpenAI-compat endpoint
VLLM_MODEL=Qwen/Qwen2.5-72B-Instruct-GPTQ-Int4 # str: HuggingFace model ID

# Groq (cloud, priority 2 — free tier, rate-limited)
GROQ_API_KEY=gsk_CHANGEME                       # str: Groq API key (starts with gsk_)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct  # str: Groq vision model
GROQ_TEXT_MODEL=llama-3.3-70b-versatile         # str: Groq text model

# OpenRouter (cloud, priority 3 — pay-per-token fallback)
OPENROUTER_API_KEY=sk-or-CHANGEME               # str: OpenRouter API key (starts with sk-or-)
OPENROUTER_REASONING_MODEL=openai/gpt-oss-120b:free  # str: high-reasoning model
OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free  # str: vision fallback model

# ─── Composio MCP ─────────────────────────────────────────────

COMPOSIO_API_KEY=CHANGEME                        # str: Composio API key

# ─── Memory (Qdrant) ──────────────────────────────────────────

QDRANT_URL=http://localhost:6333                 # str: Qdrant HTTP endpoint
QDRANT_COLLECTION=orion_tasks                    # str: Vector collection name

# ─── Observability ────────────────────────────────────────────

LANGSMITH_API_KEY=CHANGEME                       # str: LangSmith API key
LANGSMITH_PROJECT=orion                          # str: LangSmith project name

# ─── Safety ───────────────────────────────────────────────────

ORION_SAFETY_MODE=strict                         # enum(strict,permissive): enforcement level
ORION_TASK_TIMEOUT_SECONDS=300                   # int: global task timeout in seconds
ORION_MAX_EXECUTOR_ITERATIONS=20                 # int: max executor steps per task
